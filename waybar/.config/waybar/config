{
    "layer": "top",
    "position": "top",
    "spacing": 2,
    "mod": "dock",
    "exclusive": true,
    "passthrough": false,
    "gtk-layer-shell": true,
    "height": 30,
    "modules-left": ["custom/launcher", "hyprland/workspaces", "hyprland/window"],
    "modules-center": ["custom/notification", "clock"],
    "modules-right": ["custom/spotify", "network", "cpu", "memory", "pulseaudio", "tray", "custom/power"],

    "hyprland/workspaces": {
        "format": "{icon}",
