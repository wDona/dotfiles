#!/usr/bin/env bash
# Switcher de ventanas via rofi.
# Al elegir una ventana, focuswindow salta a su workspace en el monitor que le toca.
set -euo pipefail

sel=$(hyprctl clients -j \
  | jq -r '.[] | select(.mapped == true and .workspace.id > -99)
           | "\(.address)\t[\(.workspace.name)] \(.class) — \(.title)"' \
  | rofi -dmenu -i -p "Ventanas" -display-columns 2) || exit 0

addr=$(printf '%s' "$sel" | cut -f1)
[ -n "$addr" ] && hyprctl dispatch focuswindow "address:$addr"
